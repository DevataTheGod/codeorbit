# ─── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"   # Found in Supabase Dashboard → Settings → API
VITE_OTP_SERVER_URL="http://localhost:8787"
# VITE_OTP_SERVER_API_KEY=""                        # Shared secret matching OTP_SERVER_API_KEY below

# ─── Backend Express OTP Server ────────────────────────────────────────────────
PORT="8787"
FRONTEND_ORIGIN="http://localhost:8080"
RESEND_API_KEY="your-resend-api-key"              # From resend.com dashboard
OTP_FROM_EMAIL="onboarding@resend.dev"            # Verified sender address

# ─── Supabase Edge Function Secrets (set via `supabase secrets set`) ───────────
# GEMINI_API_KEY="your-gemini-api-key"
